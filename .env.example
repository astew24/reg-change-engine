# Copy to .env and fill in values before running.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/regchanges

# Directory to cache downloaded Federal Register XML files
DATA_DIR=data

# HuggingFace model for zero-shot domain classification
# Default: cross-encoder/nli-distilroberta-base (no fine-tuning required)
# Swap for a fine-tuned checkpoint to improve accuracy:
CLASSIFIER_MODEL=cross-encoder/nli-distilroberta-base
